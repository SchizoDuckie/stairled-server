<div class="modal fade" id="connectionCheckModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">
                    <i class="fas fa-wifi me-2"></i>{{title}}
                </h5>
            </div>
            <div class="modal-body">
                {{{connectionSteps}}}
                
                <div class="progress mt-3">
                    <div class="progress-bar progress-bar-striped progress-bar-animated" 
                         role="progressbar" 
                         style="width: 100%">
                        Time remaining: <span class="countdown">120</span>s
                    </div>
                </div>
                
                <div class="status-message mt-3 small text-muted">
                    Attempting to reach: <span class="hostname-instruction">{{hostname}}</span>
                </div>
            </div>
        </div>
    </div>
</div> 