<div class="card network-devices-card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">

                <i class="fas fa-network-wired me-2"></i>Discovered Devices
            </h5>
            <button type="button" class="btn btn-sm btn-outline-primary refresh-devices">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
        </div>
    </div>
    <div class="card-body">
        <div class="discovered-devices-list">
            {{#if devices.length}}
                <div class="list-group">
                    {{#each devices}}
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">
                                        <i class="fas {{serviceIcon service}} me-2"></i>
                                        {{hostname}}
                                    </h6>
                                    <small class="text-muted">
                                        {{ip}}:{{port}} ({{service}})
                                    </small>
                                </div>
                                {{#if txt}}
                                    <button class="btn btn-sm btn-link show-details" type="button" data-bs-toggle="collapse" data-bs-target="#details-{{@index}}">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                {{/if}}
                            </div>
                            {{#if txt}}
                                <div class="collapse mt-2" id="details-{{@index}}">
                                    <div class="card card-body">
                                        <dl class="row mb-0">
                                            {{#each txt}}
                                                <dt class="col-sm-3">{{@key}}</dt>
                                                <dd class="col-sm-9">{{this}}</dd>
                                            {{/each}}
                                        </dl>
                                    </div>
                                </div>
                            {{/if}}
                        </div>
                    {{/each}}
                </div>
            {{else}}
                <div class="text-center text-muted">
                    <i class="fas fa-search me-2"></i>No devices discovered
                </div>
            {{/if}}
        </div>
    </div>
</div> 